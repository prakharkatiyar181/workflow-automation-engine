# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=workflow_engine
POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow_secret
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS (comma-separated origins, no trailing slash) ─────────────────────────
# CORS_ALLOWED_ORIGINS=http://localhost:5173
